---
import Layout from '../layouts/Layout.astro';
import Ruleta from '../components/Ruleta.astro'; // 1. IMPORTAMOS LA RULETA
---

<Layout showLevelButtons={true}>
  <div class="game-container">
    <h1 class="level-title">Nivel Alfa</h1>

    <div class="screen">
      <h2 id="math-question">Cargando...</h2>
    </div>

    <div class="fruits-container" id="options-container"></div>

    <p id="feedback-message" class="feedback"></p>

    <Ruleta />
  </div>
</Layout>

<style>
  /* ... Tu CSS original se mantiene exactamente igual ... */
  .game-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    margin-top: 2rem;
    animation: fadeInUp 0.6s ease-out;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .level-title {
    font-size: 2.2rem;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: #f8fafc;
    font-weight: 800;
    text-shadow: 2px 2px 10px rgba(15, 23, 42, 0.2);
    filter: drop-shadow(1px 1px 4px rgba(15, 23, 42, 0.15));
  }

  .screen {
    background: rgba(255, 255, 255, 0.24);
    backdrop-filter: blur(20px);
    color: #1e1b4b;
    padding: 2.5rem 5rem;
    border-radius: 28px;
    border: 1px solid rgba(255, 255, 255, 0.45);
    background-clip: padding-box;
    box-shadow: 
      0 18px 48px rgba(15, 23, 42, 0.14),
      inset 0 0 0 1px rgba(255, 255, 255, 0.5);
    margin-bottom: 2.5rem;
    min-width: 360px;
    position: relative;
  }

  .screen::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 26px;
    background: rgba(255, 255, 255, 0.18);
    z-index: -1;
  }

  #math-question {
    font-size: 4rem;
    margin: 0;
    font-family: 'Fredoka', monospace;
    letter-spacing: 5px;
    color: #1e1b4b;
  }

  .fruits-container {
    display: flex;
    gap: 2rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  :global(.fruit-btn) {
    background: rgba(255, 255, 255, 0.18);
    border: 1px solid rgba(255, 255, 255, 0.5);
    color: #ffffff;
    font-size: 2.1rem;
    font-weight: 800;
    padding: 1.6rem 2.4rem;
    border-radius: 32px;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    min-width: 220px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.16);
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(16px);
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  :global(.fruit-btn::before) {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.28) 0%, rgba(255,255,255,0.08) 40%, transparent 100%);
    pointer-events: none;
  }

  :global(.fruit-btn:hover) {
    transform: translateY(-10px) scale(1.03);
    box-shadow: 0 24px 50px rgba(0, 0, 0, 0.2);
  }

  :global(.fruit-btn.blue-card) {
    background: rgba(59, 130, 246, 0.24);
    border-color: rgba(59, 130, 246, 0.55);
  }

  :global(.fruit-btn.green-card) {
    background: rgba(16, 185, 129, 0.24);
    border-color: rgba(16, 185, 129, 0.55);
  }

  :global(.fruit-btn.red-card) {
    background: rgba(239, 68, 68, 0.24);
    border-color: rgba(239, 68, 68, 0.55);
  }

  :global(.fruit-btn.yellow-card) {
    background: rgba(234, 179, 8, 0.24);
    border-color: rgba(234, 179, 8, 0.55);
    color: #1f2937;
  }

  :global(.fruit-btn:active) {
    transform: translateY(-2px) scale(0.98);
  }

  .feedback {
    font-size: 1.5rem;
    font-weight: bold;
    margin-top: 2rem;
    min-height: 2rem;
  }

  :global(.correct) {
    color: #16a34a;
    animation: correctPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  :global(.incorrect) {
    color: #ef4444;
    animation: shake 0.5s ease;
  }

  @keyframes correctPop {
    0% { transform: scale(0.5); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-10px); }
    75% { transform: translateX(10px); }
  }
</style>

<script>
  import confetti from 'canvas-confetti';

  const questionEl = document.getElementById('math-question');
  const optionsContainer = document.getElementById('options-container');
  const feedbackEl = document.getElementById('feedback-message');

  function generateQuestion() {
    let var1 = Math.floor(Math.random() * 15) + 1;
    let var2 = Math.floor(Math.random() * 15) + 1;

    const isAddition = Math.random() > 0.5;

    if (!isAddition && var1 < var2) {
      let temp = var1;
      var1 = var2;
      var2 = temp;
    }

    const correctAnswer = isAddition ? (var1 + var2) : (var1 - var2);
    const operator = isAddition ? '+' : '-';

    let wrong1 = correctAnswer + Math.floor(Math.random() * 3) + 1;
    if (wrong1 === correctAnswer) wrong1 += 1;

    const options = [
      { value: correctAnswer, isCorrect: true },
      { value: wrong1, isCorrect: false }
    ];

    options.sort(() => Math.random() - 0.5);

    if (questionEl) {
      questionEl.textContent = `${var1} ${operator} ${var2} = ?`;
    }

    renderOptions(options);
  }

  function renderOptions(options: { value: number; isCorrect: boolean }[]) {
    if (!optionsContainer) return;
    optionsContainer.innerHTML = '';

    const labels = ['A', 'B'];
    const colorClasses = ['blue-card', 'green-card', 'red-card', 'yellow-card'];

    options.forEach((opt, index) => {
      const btn = document.createElement('button');
      btn.className = `fruit-btn ${colorClasses[index % colorClasses.length]}`;
      btn.textContent = `Opción ${labels[index]}: ${opt.value}`;

      btn.addEventListener('click', () => {
        checkAnswer(opt.isCorrect);
      });

      optionsContainer.appendChild(btn);
    });
  }

  function checkAnswer(isCorrect: boolean) {
    if (!feedbackEl || !optionsContainer) return;

    if (isCorrect) {
      feedbackEl.textContent = "¡Correcto!";
      feedbackEl.className = "feedback correct";

      const audioGanar = new Audio('/sounds/Ganar.mp3');
      audioGanar.play();

      confetti({
        particleCount: 250,
        spread: 180,
        origin: { y: 0.6 }
      });

      // 3. CAMBIO AQUÍ: Ocultamos los botones de respuestas y disparamos la ruleta
      optionsContainer.style.display = 'none'; 
      document.dispatchEvent(new CustomEvent('respuestaCorrecta'));

    } else {
      feedbackEl.textContent = "Intenta de nuevo";
      feedbackEl.className = "feedback incorrect";

      const audioPerder = new Audio('/sounds/perder.mp3');
      audioPerder.play();

      for (let i = 0; i < 25; i++) {
        const x = document.createElement('div');
        x.textContent = '❌'; 
        x.style.position = 'fixed';
        x.style.top = '-60px';
        x.style.left = Math.random() * 100 + 'vw'; 
        x.style.fontSize = Math.random() * (65 - 40) + 40 + 'px';
        x.style.zIndex = '9999';
        x.style.pointerEvents = 'none';
        x.style.transition = 'transform 2.5s cubic-bezier(0.25, 1, 0.5, 1), opacity 2.5s ease';
        
        document.body.appendChild(x);

        setTimeout(() => {
          x.style.transform = `translateY(115vh) rotate(${Math.random() * 720 - 360}deg)`;
          x.style.opacity = '0';
          setTimeout(() => x.remove(), 2500);
        }, Math.random() * 600);
      }
    }
  }

  // 4. NUEVO: Escuchar cuando la ruleta termine su turno para pasar a la siguiente pregunta
  document.addEventListener('siguienteTurno', () => {
    if (feedbackEl) feedbackEl.textContent = "";
    if (optionsContainer) optionsContainer.style.display = 'flex'; // Regresamos las respuestas visualmente
    generateQuestion();
  });

  // 5. OPCIONAL: Escuchar cuántas casillas debe avanzar (por si tienes código de fichas aquí)
  document.addEventListener('avanzarFicha', (e: any) => {
    console.log(`Mover la ficha del jugador: ${e.detail.pasos} espacios.`);
  });

  generateQuestion();
</script>